<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.clinica.aauca.controller.DashboardController" 
            prefHeight="720.0" prefWidth="1280.0" stylesheets="@../css/style.css" styleClass="root">
    
    <!-- BARRA LATERAL (SIDEBAR LUXURY) -->
    <left>
        <VBox fx:id="sidebar" alignment="TOP_CENTER" prefWidth="260.0" spacing="0.0" styleClass="sidebar">
            <children>
                <!-- Identidad Corporativa -->
                <VBox alignment="CENTER" spacing="15.0" styleClass="sidebar-logo-container">
                    <ImageView fitHeight="80.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../img/logo_premium.png" />
                        </image>
                    </ImageView>
                    <Label text="CLÍNICA AAUCA" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-letter-spacing: 3px;" />
                    <Label text="v3.8 PLATINUM ULTRA" style="-fx-text-fill: #90A4AE; -fx-font-size: 11px; -fx-font-weight: bold;" />
                    <Separator opacity="0.1" prefWidth="200.0">
                        <padding><Insets top="20.0"/></padding>
                    </Separator>
                </VBox>
                
                <VBox fx:id="menuContainer" spacing="5.0" VBox.vgrow="ALWAYS">
                    <Button fx:id="btnDashboard" mnemonicParsing="false" onAction="#showHome" prefHeight="60.0" prefWidth="260.0" styleClass="sidebar-btn" text=" Dashboard General">
                        <graphic><FontAwesomeIconView glyphName="GAMEPAD" size="18" fill="WHITE" opacity="0.7"/></graphic>
                    </Button>
                    
                    <Button fx:id="btnPacientes" mnemonicParsing="false" onAction="#showPatients" prefHeight="60.0" prefWidth="260.0" styleClass="sidebar-btn" text=" Gestión Pacientes">
                        <graphic><FontAwesomeIconView glyphName="USERS" size="18" fill="WHITE" opacity="0.7"/></graphic>
                    </Button>
                    
                    <Button fx:id="btnCitas" mnemonicParsing="false" onAction="#showAppointments" prefHeight="60.0" prefWidth="260.0" styleClass="sidebar-btn" text=" Agenda / Citas">
                        <graphic><FontAwesomeIconView glyphName="CALENDAR" size="18" fill="WHITE" opacity="0.7"/></graphic>
                    </Button>
                    
                    <Button fx:id="btnConsultas" mnemonicParsing="false" onAction="#showHistory" prefHeight="60.0" prefWidth="260.0" styleClass="sidebar-btn" text=" Historia Médica">
                        <graphic><FontAwesomeIconView glyphName="FILE_TEXT_ALT" size="18" fill="WHITE" opacity="0.7"/></graphic>
                    </Button>
                    
                    <Button fx:id="btnFacturacion" mnemonicParsing="false" onAction="#showBilling" prefHeight="60.0" prefWidth="260.0" styleClass="sidebar-btn" text=" Facturación / POS">
                        <graphic><FontAwesomeIconView glyphName="MONEY" size="18" fill="WHITE" opacity="0.7"/></graphic>
                    </Button>
                </VBox>
                
                <!-- Botón de Salida Reforzado -->
                <Button fx:id="btnLogout" mnemonicParsing="false" onAction="#handleLogout" prefHeight="65.0" prefWidth="260.0" styleClass="sidebar-btn, sidebar-btn-exit" text=" Finalizar Sesión">
                    <graphic><FontAwesomeIconView glyphName="SIGN_OUT" size="20" fill="#E74C3C" opacity="1.0" /></graphic>
                    <padding><Insets left="30.0"/></padding>
                </Button>
            </children>
        </VBox>
    </left>
    
    <center>
        <VBox style="-fx-background-color: #F8F9FA;">
            <!-- Barra Superior VIP -->
            <HBox alignment="CENTER_RIGHT" prefHeight="85.0" spacing="20.0" styleClass="top-bar">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                        <VBox alignment="CENTER_RIGHT">
                           <Label fx:id="lblWelcome" style="-fx-font-weight: bold; -fx-text-fill: #263238; -fx-font-size: 15px;" text="Bienvenido, Dr. Aauca" />
                           <Label fx:id="lblRole" style="-fx-text-fill: #1976D2; -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-color: #E3F2FD; -fx-padding: 3 10; -fx-background-radius: 10;" text="ADMINISTRADOR" />
                        </VBox>
                        <FontAwesomeIconView glyphName="USER_CIRCLE" size="45" fill="#1565C0" />
                    </HBox>
                </children>
                <padding><Insets right="40.0"/></padding>
            </HBox>
            
            <!-- Contenedor de Vistas Estructurado -->
            <StackPane fx:id="mainContent" VBox.vgrow="ALWAYS">
                <!-- Vistas dinámicas cargadas por DashboardController -->
            </StackPane>
        </VBox>
    </center>
</BorderPane>
