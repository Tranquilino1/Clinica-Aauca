<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.clinica.aauca.controller.PatientController" 
      style="-fx-background-color: transparent;">
    
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    
    <children>
        <!-- TOP BAR: BÚSQUEDA Y TÍTULO -->
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <FontAwesomeIconView glyphName="USERS" size="30" fill="#1565C0" />
                <Label text="GESTIÓN DINÁMICA DE PACIENTES" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #263238; -fx-letter-spacing: 1px;" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 5 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                    <FontAwesomeIconView glyphName="SEARCH" size="14" fill="#90A4AE" />
                    <TextField fx:id="txtSearch" promptText="Buscar por nombre o DIP..." prefWidth="250.0" style="-fx-background-color: transparent; -fx-border-color: transparent;" onKeyReleased="#handleSearch" />
                </HBox>
            </children>
        </HBox>
        
        <!-- CUERPO PRINCIPAL: TABLA + FORMULARIO -->
        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>
                <!-- IZQUIERDA: TABLA DATOS -->
                <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                    <Label text="Directorio Clínico" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #1565C0; -fx-padding: 0 0 10 0;" />
                    <TableView fx:id="tblPatients" VBox.vgrow="ALWAYS" styleClass="modern-table" onMouseClicked="#handleRowSelect">
                        <columns>
                            <TableColumn fx:id="colDni" prefWidth="100.0" text="DIP" />
                            <TableColumn fx:id="colName" prefWidth="220.0" text="Nombre Completo" />
                            <TableColumn fx:id="colPhone" prefWidth="120.0" text="Teléfono" />
                            <TableColumn fx:id="colEmail" prefWidth="180.0" text="Email" />
                        </columns>
                        <columnResizePolicy>
                           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
                
                <!-- DERECHA: FORMULARIO CRUD -->
                <VBox prefWidth="350.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <FontAwesomeIconView glyphName="FILE_TEXT" size="20" fill="#2ECC71" />
                        <Label text="Expediente Paciente" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #263238;" />
                    </HBox>
                    <Separator opacity="0.1" />
                    
                    <VBox spacing="15.0">
                        <TextField fx:id="txtDni" promptText="Documento / DIP" style="-fx-padding: 12; -fx-background-radius: 8; -fx-background-color: #F8F9FA; -fx-border-color: #ECEFF1; -fx-border-radius: 8;" />
                        <TextField fx:id="txtFullName" promptText="Nombre Completo" style="-fx-padding: 12; -fx-background-radius: 8; -fx-background-color: #F8F9FA; -fx-border-color: #ECEFF1; -fx-border-radius: 8;" />
                        <TextField fx:id="txtPhone" promptText="Teléfono de Contacto" style="-fx-padding: 12; -fx-background-radius: 8; -fx-background-color: #F8F9FA; -fx-border-color: #ECEFF1; -fx-border-radius: 8;" />
                        <TextField fx:id="txtEmail" promptText="Correo Electrónico" style="-fx-padding: 12; -fx-background-radius: 8; -fx-background-color: #F8F9FA; -fx-border-color: #ECEFF1; -fx-border-radius: 8;" />
                        <TextField fx:id="txtAddress" promptText="Dirección" style="-fx-padding: 12; -fx-background-radius: 8; -fx-background-color: #F8F9FA; -fx-border-color: #ECEFF1; -fx-border-radius: 8;" />
                        <DatePicker fx:id="dpBirthDate" promptText="Fecha de Nacimiento" maxWidth="Infinity" style="-fx-padding: 5; -fx-background-radius: 8; -fx-background-color: #F8F9FA;" />
                    </VBox>
                    
                    <Region VBox.vgrow="ALWAYS" />
                    
                    <!-- BOTONES DE ACCIÓN CRUD -->
                    <GridPane hgap="10.0" vgap="10.0">
                        <columnConstraints>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="50.0" />
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="50.0" />
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints minHeight="10.0" prefHeight="45.0" vgrow="SOMETIMES" />
                            <RowConstraints minHeight="10.0" prefHeight="45.0" vgrow="SOMETIMES" />
                        </rowConstraints>
                        <children>
                            <Button fx:id="btnSave" mnemonicParsing="false" onAction="#handleSave" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #2ECC71; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text=" Guardar" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <graphic><FontAwesomeIconView glyphName="SAVE" fill="WHITE" /></graphic>
                            </Button>
                            <Button fx:id="btnUpdate" mnemonicParsing="false" onAction="#handleUpdate" disable="true" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text=" Actualizar" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <graphic><FontAwesomeIconView glyphName="EDIT" fill="WHITE" /></graphic>
                            </Button>
                            <Button fx:id="btnDelete" mnemonicParsing="false" onAction="#handleDelete" disable="true" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text=" Eliminar" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <graphic><FontAwesomeIconView glyphName="TRASH" fill="WHITE" /></graphic>
                            </Button>
                            <Button fx:id="btnClear" mnemonicParsing="false" onAction="#clearForm" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #95A5A6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text=" Limpiar" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <graphic><FontAwesomeIconView glyphName="ERASER" fill="WHITE" /></graphic>
                            </Button>
                        </children>
                    </GridPane>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
