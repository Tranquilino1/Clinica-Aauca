<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<HBox spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.clinica.aauca.controller.HistoryController" styleClass="module-container">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    
    <children>
        <!-- Buscador de paciente para cargar expediente -->
        <VBox prefWidth="320.0" spacing="15.0" styleClass="sidebar-inner">
            <Label text="EXPEDIENTES" styleClass="module-title" />
            <TextField fx:id="txtSearchPatient" promptText="Buscar paciente por DIP..." />
            <ListView fx:id="listPatients" VBox.vgrow="ALWAYS" />
        </VBox>

        <!-- Historial de Visitas -->
        <VBox prefWidth="250.0" spacing="10.0" styleClass="sidebar-inner">
            <Label text="CONSULTAS PREVIAS" style="-fx-font-weight: bold; -fx-text-fill: #34495e;" />
            <ListView fx:id="listHistoryEntries" VBox.vgrow="ALWAYS" />
        </VBox>
        
        <!-- Editor de Consulta Médica -->
        <VBox HBox.hgrow="ALWAYS" spacing="15.0" styleClass="card-content">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label fx:id="lblPatientName" text="Seleccione un paciente" style="-fx-font-size: 18; -fx-font-weight: 800; -fx-text-fill: #2c3e50;"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button styleClass="btn-secondary" text=" Nueva Consulta" onAction="#handleNew">
                             <graphic><FontAwesomeIconView glyphName="PLUS_CIRCLE" size="14" fill="#1976D2"/></graphic>
                        </Button>
                    </children>
                </HBox>
                <Separator />
                
                <Label text="Motivo de Consulta" styleClass="form-label" />
                <TextArea fx:id="txtReason" prefHeight="80.0" wrapText="true" promptText="Escriba el motivo de la visita..." />
                
                <Label text="Diagnóstico Médico" styleClass="form-label" />
                <TextArea fx:id="txtDiagnosis" prefHeight="100.0" wrapText="true" promptText="Escriba el diagnóstico..." />
                
                <Label text="Tratamiento / Receta" styleClass="form-label" />
                <TextArea fx:id="txtTreatment" prefHeight="100.0" wrapText="true" promptText="Prescripción y recomendaciones..." />
                
                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                    <Button fx:id="btnPDF" styleClass="btn-secondary" text=" Exportar Ficha" onAction="#handleExportPDF" disable="true">
                        <graphic><FontAwesomeIconView glyphName="FILE_PDF_O" size="14" fill="#C62828"/></graphic>
                    </Button>
                    <Button fx:id="btnReceta" styleClass="btn-secondary" text=" Generar Receta" onAction="#handleExportReceta" disable="true" style="-fx-background-color: #E8F5E9; -fx-text-fill: #2E7D32;">
                        <graphic><FontAwesomeIconView glyphName="PENCIL_SQUARE_O" size="14" fill="#2E7D32"/></graphic>
                    </Button>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button styleClass="btn-primary" text=" Guardar Consulta" onAction="#handleSave">
                        <graphic><FontAwesomeIconView glyphName="SAVE" size="14" fill="WHITE"/></graphic>
                    </Button>
                </HBox>
            </children>
        </VBox>
    </children>
</HBox>
