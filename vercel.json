{
  "version": 2,
  "name": "clinica-aauca-portal",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "INFORME_SISTEMA.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/reporte",
      "dest": "/INFORME_SISTEMA.html"
    }
  ]
}
